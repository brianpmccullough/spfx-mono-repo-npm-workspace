{
  "name": "spfx-mono-repo-npm-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "SPFx monorepo using pnpm workspaces.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.14.0 <23.0.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test"
  }
}
